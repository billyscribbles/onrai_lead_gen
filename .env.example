# Copy to .env and fill in, OR add `export APIFY_TOKEN=...` to ~/.zshrc.
# On Railway, set these as service variables instead of using a .env file.

# Apify token for live scrape runs. Get it at:
# https://console.apify.com/account/integrations
APIFY_TOKEN=

# Shared password gating the dashboard. If UNSET, the dashboard is OPEN to
# anyone with the URL — always set this in any deployed environment.
APP_PASSWORD=

# Secret used to sign the session cookie. MUST be a long random string in
# production. Generate one with: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=

# Where the SQLite DB lives. On Railway, attach a volume (e.g. mounted at /data)
# and set this to a path inside it so scraped leads survive redeploys.
# DB_PATH=/data/leads.db
