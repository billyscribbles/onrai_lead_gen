{
  "name": "lead-gen",
  "version": "1.0.0",
  "private": true,
  "description": "No-Site Radar — Melbourne no-website lead finder (FastAPI backend + React/Vite dashboard)",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"yarn dev:api\" \"yarn dev:web\"",
    "dev:api": ".venv/bin/uvicorn app.main:app --reload --port 8000",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "setup": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt && npm --prefix web install",
    "scrape": ".venv/bin/python scrape_no_website.py",
    "test": ".venv/bin/pytest -q"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
